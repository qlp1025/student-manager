<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.mapper.SysLogMapper">
    <resultMap id="BaseResultMap" type="com.student.entity.SysLog">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="operation" property="operation"/>
        <result column="method" property="method"/>
        <result column="params" property="params"/>
        <result column="ip" property="ip"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert">
        INSERT INTO sys_log (username, operation, method, params, ip)
        VALUES (#{username}, #{operation}, #{method}, #{params}, #{ip})
    </insert>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM sys_log ORDER BY create_time DESC
    </select>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM sys_log WHERE username = #{username} ORDER BY create_time DESC
    </select>

    <delete id="deleteById">
        DELETE FROM sys_log WHERE id = #{id}
    </delete>
</mapper>
