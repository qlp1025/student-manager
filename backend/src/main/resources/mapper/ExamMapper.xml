<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.mapper.ExamMapper">
    <resultMap id="BaseResultMap" type="com.student.entity.Exam">
        <id column="id" property="id"/>
        <result column="exam_name" property="examName"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM exam ORDER BY id DESC
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM exam WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam (exam_name, remark) VALUES (#{examName}, #{remark})
    </insert>

    <update id="update">
        UPDATE exam SET exam_name = #{examName}, remark = #{remark} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM exam WHERE id = #{id}
    </delete>
</mapper>
