<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.student.mapper.DatabaseMapper">

    <select id="getAllTables" resultType="java.lang.String">
        SHOW TABLES
    </select>

    <select id="getTableData" resultType="java.util.Map">
        SELECT * FROM ${tableName} LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="getTableCount" resultType="java.lang.Long">
        SELECT COUNT(*) FROM ${tableName}
    </select>

    <select id="getTableColumns" resultType="java.util.Map">
        SELECT COLUMN_NAME, DATA_TYPE, IS_NULLABLE, COLUMN_KEY, COLUMN_COMMENT
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_SCHEMA = DATABASE() AND TABLE_NAME = #{tableName}
    </select>

    <select id="executeQuery" resultType="java.util.Map">
        ${_parameter}
    </select>

</mapper>
